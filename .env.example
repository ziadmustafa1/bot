BOT_TOKEN=put_your_telegram_bot_token_here

# Comma-separated Telegram user IDs allowed to manage data files and access codes.
# Keep this set in production. Use /id in the bot to get your Telegram ID.
ADMIN_IDS=2057835002

DATA_DIR=data
DB_PATH=index/data.sqlite3
AUTH_DB_PATH=index/auth.sqlite3
TMP_DIR=tmp
MAX_RESULTS_PER_QUERY=0
MIN_PREFIX_LENGTH=6
MAX_RESULT_FILE_MB=45
SEARCH_CONCURRENCY=4
SEARCH_QUEUE_LIMIT=20
USER_COOLDOWN_SECONDS=3
